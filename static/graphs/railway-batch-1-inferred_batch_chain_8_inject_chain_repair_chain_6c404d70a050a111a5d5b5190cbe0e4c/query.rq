PREFIX base: <http://www.semanticweb.org/ontologies/2015/trainbenchmark#> PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> SELECT ?switch ?segment1 ?segment2 ?segment3 ?segment4 ?segment5 ?segment6 ?segment7 WHERE { ?switch a base:Switch . ?switch base:connectsTo ?segment1 . ?segment1 base:connectsTo ?segment2 . ?segment2 base:connectsTo ?segment3 . ?segment3 base:connectsTo ?segment4 . ?segment4 base:connectsTo ?segment5 . ?segment5 base:connectsTo ?segment6 . ?segment6 base:connectsTo ?segment7 . }