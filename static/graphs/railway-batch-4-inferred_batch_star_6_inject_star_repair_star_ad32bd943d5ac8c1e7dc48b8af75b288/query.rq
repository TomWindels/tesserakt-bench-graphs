PREFIX base: <http://www.semanticweb.org/ontologies/2015/trainbenchmark#> PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> SELECT ?switch ?sensor ?region ?position ?trackElementBefore WHERE { ?switch a base:Switch . ?switch base:monitoredBy ?sensor . ?switch a base:TrackElement . ?region base:elements ?switch . ?switch base:currentPosition ?position . ?trackElementBefore base:connectsTo ?switch . }